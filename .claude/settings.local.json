      "Bash(npm --version)",
      "Bash(npm create vite@latest . -- --template react-ts --yes)",
      "Bash(npm init -y)",
      "Bash(npm install fastify @fastify/cors @fastify/jwt @fastify/helmet)",
      "Bash(npm install)",
