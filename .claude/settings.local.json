      "Bash(npm install tailwindcss @tailwindcss/vite zustand recharts react-hook-form zod @hookform/resolvers react-router-dom axios)",
      "Bash(npm install -D @fontsource/inter @fontsource/jetbrains-mono)",
      "Bash(npx tsc --init)",
      "Bash(npm install -D eslint prettier eslint-config-prettier eslint-plugin-react eslint-plugin-react-hooks @typescript-eslint/eslint-plugin @typescript-eslint/parser)",
      "Bash(npm install pg knex dotenv)",
      "Bash(npm install -D @types/pg)",
      "Bash(npm run build)",
      "Bash(docker --version)",
      "Bash(docker-compose --version)",
      "Bash(psql --version)",
      "Bash(pg_isready)",
      "Bash(powershell.exe -Command \"docker --version\")",
      "Bash(powershell.exe -Command \"Get-Service -Name postgresql* | Select-Object Name,Status\")",
